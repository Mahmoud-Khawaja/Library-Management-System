{
  "info": {
    "name": "Library Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Authors",
      "item": [
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/authors"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"George\", \"lastName\": \"Orwell\", \"nationality\": \"British\", \"birthDate\": \"1903-06-25\"}"
            }
          }
        },
        {
          "name": "Get All Authors",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/authors?page=0&size=10&sort=id,asc"
            }
          }
        },
        {
          "name": "Get Author By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/authors/1"
            }
          }
        },
        {
          "name": "Update Author",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/authors/1"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"George\", \"lastName\": \"Orwell\", \"nationality\": \"British\", \"birthDate\": \"1903-06-25\"}"
            }
          }
        },
        {
          "name": "Delete Author",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/authors/1"
            }
          }
        },
        {
          "name": "Get Books By Author",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/authors/1/books"
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/books"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"1984\", \"isbn\": \"978-0451524935\", \"genre\": \"Dystopian\", \"publishedYear\": 1949, \"authorId\": 1}"
            }
          }
        },
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books?page=0&size=10&sort=title,asc"
            }
          }
        },
        {
          "name": "Get Book By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/1"
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/books/1"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"1984 Updated\", \"isbn\": \"978-0451524935\", \"genre\": \"Dystopian\", \"publishedYear\": 1949, \"authorId\": 1}"
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/books/1"
            }
          }
        },
        {
          "name": "Search Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/search?title=1984&genre=Dystopian&publishedYear=1949"
            }
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "Register Member",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/members"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Alice\", \"lastName\": \"Smith\", \"email\": \"alice@example.com\", \"phoneNumber\": \"01012345678\"}"
            }
          }
        },
        {
          "name": "Get All Members",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/members?page=0&size=10"
            }
          }
        },
        {
          "name": "Get Member By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/members/1"
            }
          }
        },
        {
          "name": "Search Members By Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/members/search?name=Alice"
            }
          }
        },
        {
          "name": "Update Member",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/members/1"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Alice\", \"lastName\": \"Johnson\", \"email\": \"alice.j@example.com\", \"phoneNumber\": \"01098765432\"}"
            }
          }
        },
        {
          "name": "Delete Member",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/members/1"
            }
          }
        }
      ]
    },
    {
      "name": "Borrow Records",
      "item": [
        {
          "name": "Borrow a Book",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/borrow-records"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"bookId\": 1, \"memberId\": 1}"
            }
          }
        },
        {
          "name": "Return a Book",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/borrow-records/1/return"
            }
          }
        },
        {
          "name": "Get Records By Member",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/borrow-records/member/1"
            }
          }
        },
        {
          "name": "Get Active Borrows",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/borrow-records/active"
            }
          }
        }
      ]
    }
  ]
}