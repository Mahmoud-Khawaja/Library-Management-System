  "item": [
    {
      "name": "01 - Setup",
      "item": [
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"George\",\n  \"lastName\": \"Orwell\",\n  \"nationality\": \"British\",\n  \"birthDate\": \"1903-06-25\"\n}"
            },
            "url": "{{baseUrl}}/api/authors"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.expect(json).to.have.property('data');",
                  "pm.expect(json.data).to.have.property('id');",
                  "pm.collectionVariables.set('authorId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
