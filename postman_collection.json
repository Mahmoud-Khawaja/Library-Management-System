{
  "info": {
    "name": "Library Management System API Tests",
    "description": "Postman collection to test all LMS endpoints with automatic ID chaining.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "authorId",
      "value": "1"
    },
    {
      "key": "bookId",
      "value": "1"
    },
    {
      "key": "memberId",
      "value": "1"
    },
    {
      "key": "borrowRecordId",
      "value": "1"
